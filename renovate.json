{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["github>yaizuuuu/my-renovate-config"],
  "regexManagers": [
    {
      "fileMatch": ["^\\.github/workflows/secret-scan\\.yml$"],
      "matchStrings": [
        "TARGET_HASH: (?<currentDigest>.*) # (?<currentValue>.*)"
      ],
      "datasourceTemplate": "github-tags",
      "depNameTemplate": "awslabs/git-secrets"
    }
  ]
}
